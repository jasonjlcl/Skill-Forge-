NODE_ENV=production
PORT=4000

# Application URL/origin allowlist
CORS_ORIGIN=https://app.example.com
CLIENT_URL=https://app.example.com
DOMAIN_NAME=app.example.com

# Database (prefer explicit DATABASE_URL in production)
DATABASE_URL=postgresql://postgres:change-me@postgres:5432/genai_onboarding
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_DB=genai_onboarding
DATABASE_POOL_MAX=5
DATABASE_IDLE_TIMEOUT_MS=10000
DATABASE_CONNECTION_TIMEOUT_MS=5000

JWT_SECRET=replace-with-a-very-long-random-secret-at-least-32-characters

GEMINI_API_KEY=
OPENAI_API_KEY=
# Minimum-cost production: use only Gemini for live generation and local hash
# embeddings for retrieval. Set LLM_PROVIDER=local to disable paid LLM calls too.
LLM_PROVIDER=gemini
GEMINI_MODEL=gemini-2.0-flash-lite
OPENAI_CHAT_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.2
EMBEDDING_PROVIDER=hash
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_BATCH_SIZE=64
EMBEDDING_CACHE_MAX_ENTRIES=4096

CHROMA_URL=http://chroma:8000
CHROMA_COLLECTION=training_documents
RAG_TOP_K=2
RAG_MAX_TOP_K=4
RAG_MIN_SCORE=0.08
RAG_MAX_CONTEXT_CHARS=1800
RAG_REQUIRE_CONTEXT=true
LLM_MAX_OUTPUT_TOKENS=320
LLM_TIMEOUT_MS=20000
RETRY_JITTER_RATIO=0.20
LLM_RETRY_MAX_ATTEMPTS=1
LLM_RETRY_BASE_DELAY_MS=300
LLM_RETRY_MAX_DELAY_MS=2500
LLM_CIRCUIT_FAILURE_THRESHOLD=6
LLM_CIRCUIT_OPEN_MS=45000
VECTOR_RETRY_MAX_ATTEMPTS=1
VECTOR_RETRY_BASE_DELAY_MS=200
VECTOR_RETRY_MAX_DELAY_MS=1500
VECTOR_CIRCUIT_FAILURE_THRESHOLD=6
VECTOR_CIRCUIT_OPEN_MS=30000

RATE_LIMIT_MAX=200
AUTH_RATE_LIMIT_MAX=20
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15
REQUEST_BODY_LIMIT=2mb
COOKIE_SECURE=true
STREAM_REQUEST_TTL_SECONDS=120
DATA_RETENTION_DAYS=30
OTEL_EXPORTER_MODE=none
OTEL_SERVICE_NAME=skillforge-api
OTEL_SERVICE_VERSION=
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=
OTEL_EXPORTER_OTLP_METRICS_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=
OTEL_METRIC_EXPORT_INTERVAL_MS=60000
OTEL_METRIC_EXPORT_TIMEOUT_MS=10000
LOG_HTTP_REQUESTS=false
OBSERVABILITY_SUMMARY_LOGS=false
RETENTION_JOB_AUTH_TOKEN=
RETENTION_JOB_OIDC_AUDIENCE=
RETENTION_JOB_ALLOWED_SERVICE_ACCOUNTS=
RETENTION_JOB_EDGE_SHARED_KEY=
SHUTDOWN_TIMEOUT_MS=15000

# Frontend build arg/environment
VITE_API_BASE=/api
WEB_HTTP_PORT=80
WEB_HTTPS_PORT=443

# TLS/certbot (used with docker-compose.https.yml)
ENABLE_TLS=false
CERTBOT_EMAIL=admin@app.example.com
TLS_CERT_PATH=/etc/letsencrypt/live/app.example.com/fullchain.pem
TLS_KEY_PATH=/etc/letsencrypt/live/app.example.com/privkey.pem
