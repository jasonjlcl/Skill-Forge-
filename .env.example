# Server
NODE_ENV=development
PORT=4000

# Either provide DATABASE_URL directly...
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/genai_onboarding
# ...or provide POSTGRES_* values and leave DATABASE_URL blank.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=genai_onboarding
DATABASE_POOL_MAX=10
DATABASE_IDLE_TIMEOUT_MS=30000
DATABASE_CONNECTION_TIMEOUT_MS=5000

JWT_SECRET=replace-with-a-long-random-secret-at-least-32-characters

# Allow one or more origins (comma-separated).
CORS_ORIGIN=http://localhost:5173
CLIENT_URL=http://localhost:5173

GEMINI_API_KEY=
OPENAI_API_KEY=
LLM_PROVIDER=auto
GEMINI_MODEL=gemini-1.5-flash
OPENAI_CHAT_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.2
EMBEDDING_PROVIDER=auto
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_BATCH_SIZE=64
EMBEDDING_CACHE_MAX_ENTRIES=4096

CHROMA_URL=http://localhost:8000
CHROMA_COLLECTION=training_documents
RAG_TOP_K=4
RAG_MAX_TOP_K=6
RAG_MIN_SCORE=0.05
RAG_MAX_CONTEXT_CHARS=4000
RAG_REQUIRE_CONTEXT=true
LLM_MAX_OUTPUT_TOKENS=600
LLM_TIMEOUT_MS=20000
RETRY_JITTER_RATIO=0.25
LLM_RETRY_MAX_ATTEMPTS=3
LLM_RETRY_BASE_DELAY_MS=250
LLM_RETRY_MAX_DELAY_MS=2000
LLM_CIRCUIT_FAILURE_THRESHOLD=5
LLM_CIRCUIT_OPEN_MS=30000
VECTOR_RETRY_MAX_ATTEMPTS=3
VECTOR_RETRY_BASE_DELAY_MS=250
VECTOR_RETRY_MAX_DELAY_MS=2000
VECTOR_CIRCUIT_FAILURE_THRESHOLD=5
VECTOR_CIRCUIT_OPEN_MS=30000

RATE_LIMIT_MAX=200
AUTH_RATE_LIMIT_MAX=20
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15
REQUEST_BODY_LIMIT=2mb
COOKIE_SECURE=false
STREAM_REQUEST_TTL_SECONDS=120
DATA_RETENTION_DAYS=180
OTEL_EXPORTER_MODE=none
OTEL_SERVICE_NAME=skillforge-api
OTEL_SERVICE_VERSION=
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=
OTEL_EXPORTER_OTLP_METRICS_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=
OTEL_METRIC_EXPORT_INTERVAL_MS=60000
OTEL_METRIC_EXPORT_TIMEOUT_MS=10000
LOG_HTTP_REQUESTS=true
OBSERVABILITY_SUMMARY_LOGS=true
RETENTION_JOB_AUTH_TOKEN=
RETENTION_JOB_OIDC_AUDIENCE=
RETENTION_JOB_ALLOWED_SERVICE_ACCOUNTS=
RETENTION_JOB_EDGE_SHARED_KEY=
SHUTDOWN_TIMEOUT_MS=15000

# Client
# Keep empty in local dev to use Vite proxy; set to /api for production.
VITE_API_BASE=
